@page "/tenants"
@using PropertyManagementApp.Shared
@inject HttpClient Http
@inject NavigationManager Nav

<h3>Tenants</h3>

<a class="btn btn-primary mb-3" href="/tenants/create">
    Add Tenant
</a>

@if (tenants == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Property</th>
                <th>Unit</th>
                <th>Ledger</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var tenant in tenants)
            {
                <tr>
                    <td>
                        <a href="rent-records/tenant/@tenant.TenantID">
                            @tenant.FirstName @tenant.LastName
                        </a>
                    </td>

                    <td>@tenant.Email</td>
                    <td>@tenant.PhoneNumber</td>
                    <td>@tenant.PropertyName</td>
                    <td>@tenant.UnitNumber</td>

                    <td>
                        <a class="action-btn action-reminder"
                               href="rent-records/tenant/@tenant.TenantID">
                            View Ledger
                        </a>
                    </td>

                    <td>
                        <a class="btn btn-sm btn-warning"
                               href="/tenants/edit/@tenant.TenantID">
                            Edit
                        </a>

                        <button class="btn btn-sm btn-danger"
                                @onclick="() => DeleteTenant(tenant.TenantID)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<TenantDto>? tenants;

    protected override async Task OnInitializedAsync()
    {
        await LoadTenants();
    }

    private async Task LoadTenants()
    {
        tenants = await Http.GetFromJsonAsync<List<TenantDto>>("api/tenants");
    }

    private async Task DeleteTenant(int tenantId)
    {
        var response = await Http.DeleteAsync($"api/tenants/{tenantId}");

        if (response.IsSuccessStatusCode)
        {
            await LoadTenants();
        }
    }
}