@page "/tenants/edit/{TenantID:int}"
@using PropertyManagementApp.Shared
@using PropertyManagementApp.Shared.DTOs
@inject HttpClient Http
@inject NavigationManager Nav
@inject NotificationService Notify

<div class="page-header">
    <div>
        <h3>Edit Tenant</h3>
        <p class="text-muted mb-0">Update tenant information and assigned property/unit.</p>
    </div>

    <a href="/tenants" class="btn btn-outline-secondary btn-sm">
        Back
    </a>
</div>

@if (tenant == null)
{
    <p><em>Loading...</em></p>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger py-2">
            @errorMessage
        </div>
    }

    <div class="compact-form-card">
        <EditForm Model="tenant" OnValidSubmit="UpdateTenantAsync">
            <DataAnnotationsValidator />

            <div class="row g-2">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">First Name</label>
                    <InputText class="form-control form-control-sm"
                               @bind-Value="tenant.FirstName" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Last Name</label>
                    <InputText class="form-control form-control-sm"
                               @bind-Value="tenant.LastName" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Email</label>
                    <InputText class="form-control form-control-sm"
                               type="email"
                               @bind-Value="tenant.Email" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Phone Number</label>
                    <InputText class="form-control form-control-sm"
                               @bind-Value="tenant.PhoneNumber" />
                </div>

                <div class="col-md-12">
                    <label class="form-label fw-semibold">Property</label>
                    <InputSelect class="form-select form-select-sm"
                                 @bind-Value="tenant.PropertyID">
                        <option value="0">Choose a property</option>

                        @foreach (var property in properties)
                        {
                            <option value="@property.PropertyID">
                                @property.PropertyName - @property.Address - Unit @property.UnitNumber
                            </option>
                        }
                    </InputSelect>
                </div>
            </div>

            <div class="compact-form-actions">
                <button type="submit" class="btn btn-primary btn-sm" disabled="@isSaving">
                    @(isSaving ? "Saving..." : "Save Changes")
                </button>

                <a href="/tenants" class="btn btn-outline-secondary btn-sm">
                    Cancel
                </a>
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter]
    public int TenantID { get; set; }

    private TenantDto? tenant;
    private List<PropertyDto> properties = new();
    private string? errorMessage;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        properties = await Http.GetFromJsonAsync<List<PropertyDto>>("api/properties") ?? new();
        tenant = await Http.GetFromJsonAsync<TenantDto>($"api/tenants/{TenantID}");
    }

    private async Task UpdateTenantAsync()
    {
        if (tenant == null)
        {
            return;
        }

        errorMessage = ValidateTenant();

        if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            return;
        }

        isSaving = true;

        try
        {
            var response = await Http.PutAsJsonAsync($"api/tenants/{TenantID}", tenant);

            if (response.IsSuccessStatusCode)
            {
                Notify.Success("Tenant updated successfully.");
                Nav.NavigateTo("/tenants");
                return;
            }

            errorMessage = await GetErrorMessageAsync(response);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating tenant: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private string? ValidateTenant()
    {
        if (tenant == null)
        {
            return "Tenant could not be loaded.";
        }

        if (string.IsNullOrWhiteSpace(tenant.FirstName))
        {
            return "First name is required.";
        }

        if (string.IsNullOrWhiteSpace(tenant.LastName))
        {
            return "Last name is required.";
        }

        if (string.IsNullOrWhiteSpace(tenant.Email))
        {
            return "Email is required.";
        }

        if (!tenant.Email.Contains("@"))
        {
            return "Email format is not valid.";
        }

        if (tenant.PropertyID <= 0)
        {
            return "Please select a property.";
        }

        return null;
    }

    private async Task<string> GetErrorMessageAsync(HttpResponseMessage response)
    {
        var content = await response.Content.ReadAsStringAsync();

        return string.IsNullOrWhiteSpace(content)
            ? "The tenant could not be saved."
            : content;
    }
}