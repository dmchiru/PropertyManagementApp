@page "/"

<h1>Property Management Dashboard</h1>

<p class="text-muted">
    Manage properties, tenants, rent collection, maintenance, invoices, and eviction preparation from one place.
</p>

<Dashboard />

<div class="home-grid">
    <a class="home-card" href="properties">
        <h3>Properties</h3>
        <p>View properties, units, rent amounts, and choose an active property.</p>
    </a>

    <a class="home-card" href="tenants">
        <h3>Tenants</h3>
        <p>View tenant records and assigned units.</p>
    </a>

    <a class="home-card" href="rent-collection">
        <h3>Rent Collection</h3>
        <p>Track payments, unpaid balances, and late rent.</p>
    </a>

    <a class="home-card" href="maintenance">
        <h3>Maintenance</h3>
        <p>Manage work orders and proof records.</p>
    </a>

    <a class="home-card" href="invoicing">
        <h3>Invoicing</h3>
        <p>Create invoices and track payment status.</p>
    </a>

    <a class="home-card" href="eviction-prep">
        <h3>Eviction Prep</h3>
        <p>Prepare notices and track eviction case workflow.</p>
    </a>

    <a class="home-card" href="communications">
        <h3>Communications</h3>
        <p>Review reminders, notices, and tenant contact history.</p>
    </a>
</div>