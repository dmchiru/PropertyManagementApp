@page "/communications"
@using PropertyManagementApp.Shared.DTOs
@inject HttpClient Http

<h2 class="mb-4">Communication Logs</h2>

@if (logs == null)
{
    <p>Loading...</p>
}
else
{
    <table class="table modern-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Tenant</th>
                <th>Channel</th>
                <th>Template</th>
                <th>Message</th>
                <th>Sent By</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var log in logs)
            {
                <tr>
                    <td>@log.SentAt.ToString("g")</td>
                    <td>@log.TenantName</td>
                    <td>@log.Channel</td>
                    <td>@log.TemplateUsed</td>
                    <td>@log.MessageBody</td>
                    <td>@log.SentBy</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<CommunicationLogDto>? logs;

    protected override async Task OnInitializedAsync()
    {
        logs = await Http.GetFromJsonAsync<List<CommunicationLogDto>>("api/communications");
    }
}