@page "/maintenance"
@using PropertyManagementApp.Shared
@using PropertyManagementApp.Shared.DTOs
@inject HttpClient Http
@inject IJSRuntime JS
@inject NotificationService Notify

<div class="page-header">
    <div>
        <h3>Maintenance</h3>
        <p class="text-muted mb-0">Manage work orders, vendors, bids, and project status.</p>
    </div>

    <button class="btn btn-primary btn-sm" @onclick="ToggleCreate">
        @(showForm ? "Cancel" : "Add Project")
    </button>
</div>

@if (projects == null || properties == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="dashboard-cards compact-dashboard-cards">
        <div class="card">
            <h4>Total Projects</h4>
            <p>@projects.Count</p>
        </div>

        <div class="card success">
            <h4>Closed</h4>
            <p>@projects.Count(x => x.Status == "Closed")</p>
        </div>

        <div class="card warning">
            <h4>Active</h4>
            <p>@projects.Count(x => x.Status != "Closed")</p>
        </div>

        <div class="card danger">
            <h4>Total Bids</h4>
            <p>@projects.Sum(x => x.BidAmount).ToString("C")</p>
        </div>
    </div>

    @if (showForm)
    {
        <div class="compact-search-card">
            <h5 class="mb-3">Create Maintenance Project</h5>

            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Property</label>
                    <select class="form-select form-select-sm" @bind="newProject.PropertyID">
                        <option value="0">Choose a property</option>

                        @foreach (var property in properties)
                        {
                            <option value="@property.PropertyID">
                                @property.PropertyName - Unit @property.UnitNumber
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Project Title</label>
                    <input class="form-control form-control-sm"
                           placeholder="Project Title"
                           @bind="newProject.ProjectTitle" />
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Vendor</label>
                    <input class="form-control form-control-sm"
                           placeholder="Assigned Vendor"
                           @bind="newProject.AssignedVendor" />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Bid Amount</label>
                    <input type="number"
                           class="form-control form-control-sm"
                           placeholder="Bid Amount"
                           @bind="newProject.BidAmount" />
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success btn-sm" @onclick="CreateProject">
                    Save Project
                </button>

                <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleCreate">
                    Cancel
                </button>
            </div>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
            <thead>
                <tr>
                    <th>Project</th>
                    <th>Property</th>
                    <th>Vendor</th>
                    <th>Status</th>
                    <th>Bid Amount</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var project in projects)
                {
                    <tr>
                        <td class="fw-semibold">@project.ProjectTitle</td>
                        <td>@project.PropertyName</td>
                        <td>@project.AssignedVendor</td>

                        <td>
                            <span class="compact-pill @GetStatusClass(project.Status)">
                                @project.Status
                            </span>
                        </td>

                        <td class="fw-semibold">
                            @project.BidAmount.ToString("C")
                        </td>

                        <td>
                            <div class="compact-action-group">
                                <a class="btn btn-sm btn-outline-secondary compact-action"
                                       href="/worklogs/@project.ProjectID">
                                    Logs
                                </a>

                                @if (project.Status != "Closed")
                                {
                                    <button class="btn btn-sm btn-outline-primary compact-action"
                                            @onclick="() => Start(project.ProjectID)">
                                        Start
                                    </button>

                                    <button class="btn btn-sm btn-outline-success compact-action"
                                            @onclick="() => Complete(project.ProjectID)">
                                        Close
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-secondary compact-action" disabled>
                                        Complete
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private const string SelectedPropertyKey = "propertyManagement.selectedPropertyId";

    private List<MaintenanceProjectDto>? projects;
    private List<PropertyDto>? properties;

    private bool showForm;
    private CreateMaintenanceProjectDto newProject = new();

    protected override async Task OnInitializedAsync()
    {
        await Load();
        await LoadSelectedPropertyAsync();
    }

    private async Task Load()
    {
        projects = await Http.GetFromJsonAsync<List<MaintenanceProjectDto>>("api/maintenanceprojects") ?? new();
        properties = await Http.GetFromJsonAsync<List<PropertyDto>>("api/properties") ?? new();
    }

    private async Task LoadSelectedPropertyAsync()
    {
        var savedValue = await JS.InvokeAsync<string?>("localStorage.getItem", SelectedPropertyKey);

        if (int.TryParse(savedValue, out var propertyId) && propertyId > 0)
        {
            newProject.PropertyID = propertyId;
        }
    }

    private void ToggleCreate()
    {
        showForm = !showForm;
    }

    private async Task CreateProject()
    {
        if (newProject.PropertyID <= 0)
        {
            Notify.Error("Please choose a property.");
            return;
        }

        if (string.IsNullOrWhiteSpace(newProject.ProjectTitle))
        {
            Notify.Error("Project title is required.");
            return;
        }

        var response = await Http.PostAsJsonAsync("api/maintenanceprojects", newProject);

        if (response.IsSuccessStatusCode)
        {
            Notify.Success("Maintenance project created.");

            showForm = false;
            newProject = new CreateMaintenanceProjectDto();

            await LoadSelectedPropertyAsync();
            await Load();
        }
        else
        {
            Notify.Error("Failed to create maintenance project.");
        }
    }

    private async Task Start(int id)
    {
        var response = await Http.PostAsync($"api/maintenanceprojects/{id}/start", null);

        if (response.IsSuccessStatusCode)
        {
            Notify.Success("Project moved to Work Order.");
            await Load();
        }
        else
        {
            Notify.Error("Failed to start project.");
        }
    }

    private async Task Complete(int id)
    {
        var response = await Http.PostAsync($"api/maintenanceprojects/{id}/complete", null);

        if (response.IsSuccessStatusCode)
        {
            Notify.Success("Project closed.");
            await Load();
        }
        else
        {
            Notify.Error("Failed to close project.");
        }
    }

    private string GetStatusClass(string? status)
    {
        return status switch
        {
            "Closed" => "pill-success",
            "Work Order" => "pill-warning",
            "Invoiced" => "pill-warning",
            "Approved" => "pill-warning",
            "Bid" => "pill-dark",
            _ => "pill-muted"
        };
    }
}