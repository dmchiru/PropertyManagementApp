@page "/maintenance"
@using PropertyManagementApp.Shared.DTOs
@inject HttpClient Http
@inject NotificationService Notify

<h2 class="mb-4">Maintenance Dashboard</h2>

@if (projects == null)
{
    <p>Loading...</p>
}
else
{
    <div class="dashboard-cards">
        <div class="card">
            <h4>Total Projects</h4>
            <p>@projects.Count</p>
        </div>

        <div class="card success">
            <h4>Closed</h4>
            <p>@projects.Count(x => x.Status == "Closed")</p>
        </div>

        <div class="card warning">
            <h4>Active</h4>
            <p>@projects.Count(x => x.Status != "Closed")</p>
        </div>

        <div class="card danger">
            <h4>Total Bids</h4>
            <p>@projects.Sum(x => x.BidAmount).ToString("C")</p>
        </div>
    </div>

    <div class="invoice-toolbar">
        <button class="action-btn action-paid" @onclick="ToggleCreate">
            @(showForm ? "Cancel" : "+ New Maintenance Project")
        </button>
    </div>

    @if (showForm)
    {
        <div class="card p-3 mb-3">
            <h4>Create Maintenance Project</h4>

            <input class="form-control mb-2"
                   placeholder="Project Title"
                   @bind="newProject.ProjectTitle" />

            <input class="form-control mb-2"
                   placeholder="Assigned Vendor"
                   @bind="newProject.AssignedVendor" />

            <input type="number"
                   class="form-control mb-2"
                   placeholder="Property ID"
                   @bind="newProject.PropertyID" />

            <input type="number"
                   class="form-control mb-2"
                   placeholder="Bid Amount"
                   @bind="newProject.BidAmount" />

            <button class="action-btn action-paid" @onclick="CreateProject">
                Save Project
            </button>
        </div>
    }

    <table class="table modern-table">
        <thead>
            <tr>
                <th>Project</th>
                <th>Property</th>
                <th>Vendor</th>
                <th>Status</th>
                <th>Bid Amount</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var p in projects)
            {
                <tr>
                    <td>@p.ProjectTitle</td>
                    <td>@p.PropertyName</td>
                    <td>@p.AssignedVendor</td>

                    <td>
                        <span class="badge @GetStatusClass(p.Status)">
                            @p.Status
                        </span>
                    </td>

                    <td>@p.BidAmount.ToString("C")</td>

                    <td>
                        @if (p.Status == "Closed")
                        {
                            <span class="badge badge-success">Complete</span>
                        }
                        else
                        {
                            <div class="action-buttons">
                                <a class="action-btn action-reminder"
                                       href="/worklogs/@p.ProjectID">
                                    View Logs
                                </a>

                                <button class="action-btn action-reminder"
                                        @onclick="() => Start(p.ProjectID)">
                                    Start Work
                                </button>

                                <button class="action-btn action-paid"
                                        @onclick="() => Complete(p.ProjectID)">
                                    Close
                                </button>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<MaintenanceProjectDto>? projects;

    private bool showForm = false;

    private CreateMaintenanceProjectDto newProject = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            projects = await Http.GetFromJsonAsync<List<MaintenanceProjectDto>>("api/maintenanceprojects");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    private async Task Load()
    {
        projects = await Http.GetFromJsonAsync<List<MaintenanceProjectDto>>("api/maintenanceprojects");
    }

    private void ToggleCreate()
    {
        showForm = !showForm;
    }

    private async Task CreateProject()
    {
        if (string.IsNullOrWhiteSpace(newProject.ProjectTitle))
        {
            Notify.Error("Project title is required.");
            return;
        }

        if (newProject.PropertyID <= 0)
        {
            Notify.Error("Property ID is required.");
            return;
        }

        var response = await Http.PostAsJsonAsync("api/maintenanceprojects", newProject);

        if (response.IsSuccessStatusCode)
        {
            Notify.Success("Maintenance project created.");
            showForm = false;
            newProject = new CreateMaintenanceProjectDto();
            await Load();
        }
        else
        {
            Notify.Error("Failed to create maintenance project.");
        }
    }

    private async Task Start(int id)
    {
        await Http.PostAsync($"api/maintenanceprojects/{id}/start", null);
        Notify.Success("Project moved to Work Order.");
        await Load();
    }

    private async Task Complete(int id)
    {
        await Http.PostAsync($"api/maintenanceprojects/{id}/complete", null);
        Notify.Success("Project closed.");
        await Load();
    }

    private string GetStatusClass(string? status)
    {
        return status switch
        {
            "Closed" => "badge-success",
            "Work Order" => "badge-warning",
            "Invoiced" => "badge-warning",
            "Approved" => "badge-warning",
            "Bid" => "badge-default",
            _ => "badge-default"
        };
    }
}