@page "/eviction-prep"
@inject HttpClient Http
@inject NotificationService Notify

<div class="page-header">
    <div>
        <h3>Eviction Prep</h3>
        <p class="text-muted mb-0">Track eviction cases, notices, timelines, and document preparation.</p>
    </div>

    <button class="btn btn-primary btn-sm" @onclick="ToggleCreate">
        @(showForm ? "Cancel" : "Start Case")
    </button>
</div>

<div class="alert alert-warning py-2">
    <strong>Legal Disclaimer:</strong>
    This toolkit provides document templates and process guidance only. It is not legal advice.
</div>

@if (cases == null || tenants == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="dashboard-cards compact-dashboard-cards">
        <div class="card">
            <h4>Total Cases</h4>
            <p>@cases.Count</p>
        </div>

        <div class="card warning">
            <h4>Open</h4>
            <p>@cases.Count(x => x.Status != "Closed")</p>
        </div>

        <div class="card success">
            <h4>Closed</h4>
            <p>@cases.Count(x => x.Status == "Closed")</p>
        </div>

        <div class="card danger">
            <h4>Late Rent</h4>
            <p>@cases.Count(x => x.Reason == "Late Rent")</p>
        </div>
    </div>

    @if (showForm)
    {
        <div class="compact-search-card">
            <h5 class="mb-3">Start New Eviction Case</h5>

            <div class="row g-2">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Tenant</label>
                    <select class="form-select form-select-sm" @bind="newCase.TenantID">
                        <option value="0">Choose a tenant</option>

                        @foreach (var tenant in tenants)
                        {
                            <option value="@tenant.TenantID">
                                @tenant.FirstName @tenant.LastName - @tenant.PropertyName Unit @tenant.UnitNumber
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Reason</label>
                    <select class="form-select form-select-sm" @bind="newCase.Reason">
                        <option value="">Choose a reason</option>
                        <option value="Late Rent">Late Rent</option>
                        <option value="Lease Violation">Lease Violation</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success btn-sm" @onclick="CreateCase">
                    Save Case
                </button>

                <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleCreate">
                    Cancel
                </button>
            </div>
        </div>
    }

    <div class="compact-search-card">
        <div class="row g-2 align-items-end">
            <div class="col-md-8">
                <label class="form-label fw-semibold">Search Cases</label>
                <input class="form-control form-control-sm"
                       placeholder="Search by tenant, property, reason, status, or current step..."
                       @bind="searchText"
                       @bind:event="oninput" />
            </div>

            <div class="col-md-4">
                <label class="form-label fw-semibold">Status Filter</label>
                <select class="form-select form-select-sm" @bind="statusFilter">
                    <option value="">All statuses</option>
                    <option value="Open">Open</option>
                    <option value="Closed">Closed</option>
                    <option value="In Progress">In Progress</option>
                </select>
            </div>
        </div>
    </div>

    @if (!FilteredCases.Any())
    {
        <div class="alert alert-info">
            No eviction cases found.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead>
                    <tr>
                        <th>Case ID</th>
                        <th>Tenant</th>
                        <th>Property</th>
                        <th>Reason</th>
                        <th>Current Step</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var evictionCase in FilteredCases)
                    {
                        <tr>
                            <td class="fw-semibold">#@evictionCase.CaseID</td>
                            <td class="fw-semibold">@evictionCase.TenantName</td>
                            <td>@evictionCase.PropertyName</td>

                            <td>
                                <span class="compact-pill pill-dark">@evictionCase.Reason</span>
                            </td>

                            <td>@evictionCase.CurrentStep</td>

                            <td>
                                <span class="compact-pill @GetStatusClass(evictionCase.Status)">
                                    @evictionCase.Status
                                </span>
                            </td>

                            <td>
                                <div class="compact-action-group">
                                    <button class="btn btn-sm btn-outline-primary compact-action"
                                            @onclick="() => AdvanceCase(evictionCase.CaseID)">
                                        Advance
                                    </button>

                                    @if (evictionCase.Status != "Closed")
                                    {
                                        <button class="btn btn-sm btn-outline-success compact-action"
                                                @onclick="() => CloseCase(evictionCase.CaseID)">
                                            Close
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-secondary compact-action" disabled>
                                            Closed
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private List<EvictionCaseDto>? cases;
    private List<TenantDto>? tenants;

    private string searchText = string.Empty;
    private string statusFilter = string.Empty;
    private bool showForm;

    private CreateEvictionCaseDto newCase = new();

    private IEnumerable<EvictionCaseDto> FilteredCases
    {
        get
        {
            if (cases == null)
            {
                return Enumerable.Empty<EvictionCaseDto>();
            }

            var query = cases.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(statusFilter))
            {
                query = query.Where(item =>
                    string.Equals(item.Status, statusFilter, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(item =>
                    ContainsText(item.TenantName) ||
                    ContainsText(item.PropertyName) ||
                    ContainsText(item.Reason) ||
                    ContainsText(item.Status) ||
                    ContainsText(item.CurrentStep));
            }

            return query;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        cases = await Http.GetFromJsonAsync<List<EvictionCaseDto>>("api/evictioncases") ?? new();
        tenants = await Http.GetFromJsonAsync<List<TenantDto>>("api/tenants") ?? new();
    }

    private void ToggleCreate()
    {
        showForm = !showForm;
    }

    private async Task CreateCase()
    {
        if (newCase.TenantID <= 0)
        {
            Notify.Error("Please choose a tenant.");
            return;
        }

        if (string.IsNullOrWhiteSpace(newCase.Reason))
        {
            Notify.Error("Please choose a reason.");
            return;
        }

        var response = await Http.PostAsJsonAsync("api/evictioncases", newCase);

        if (response.IsSuccessStatusCode)
        {
            Notify.Success("Eviction case created.");

            showForm = false;
            newCase = new CreateEvictionCaseDto();

            await LoadData();
        }
        else
        {
            Notify.Error("Failed to create eviction case.");
        }
    }

    private async Task AdvanceCase(int caseId)
    {
        var response = await Http.PostAsync($"api/evictioncases/{caseId}/advance", null);

        if (response.IsSuccessStatusCode)
        {
            Notify.Success("Eviction case advanced.");
            await LoadData();
        }
        else
        {
            Notify.Error("Failed to advance eviction case.");
        }
    }

    private async Task CloseCase(int caseId)
    {
        var response = await Http.PostAsync($"api/evictioncases/{caseId}/close", null);

        if (response.IsSuccessStatusCode)
        {
            Notify.Success("Eviction case closed.");
            await LoadData();
        }
        else
        {
            Notify.Error("Failed to close eviction case.");
        }
    }

    private string GetStatusClass(string? status)
    {
        return status switch
        {
            "Closed" => "pill-success",
            "Open" => "pill-warning",
            "In Progress" => "pill-dark",
            _ => "pill-muted"
        };
    }

    private bool ContainsText(string? value)
    {
        return !string.IsNullOrWhiteSpace(value) &&
               value.Contains(searchText, StringComparison.OrdinalIgnoreCase);
    }
}