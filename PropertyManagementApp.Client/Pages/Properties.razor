@page "/properties"
@using PropertyManagementApp.Shared.DTOs
@inject HttpClient Http
@inject IJSRuntime JS
@inject NotificationService Notify

<div class="page-header">
    <div>
        <h3>Properties</h3>
        <p class="text-muted mb-0">Manage properties, units, rent amounts, and active property selection.</p>
    </div>

    <a class="btn btn-primary btn-sm" href="/properties/create">
        Add Property
    </a>
</div>

@if (properties == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="compact-search-card">
        <label class="form-label fw-semibold">Active Property</label>

        <select class="form-control form-control-sm" value="@selectedPropertyId" @onchange="SelectPropertyAsync">
            <option value="0">All properties</option>

            @foreach (var property in properties)
            {
                <option value="@property.PropertyID">
                    @property.PropertyName - @property.Address - Unit @property.UnitNumber
                </option>
            }
        </select>
    </div>

    @if (SelectedProperty != null)
    {
        <div class="alert alert-success py-2">
            Active property:
            <strong>@SelectedProperty.PropertyName</strong>,
            @SelectedProperty.Address,
            Unit @SelectedProperty.UnitNumber
        </div>
    }

    <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
            <thead>
                <tr>
                    <th>Property Name</th>
                    <th>Address</th>
                    <th>Unit</th>
                    <th>Monthly Rent</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var property in properties)
                {
                    <tr>
                        <td class="fw-semibold">@property.PropertyName</td>
                        <td>@property.Address</td>

                        <td>
                            <span class="compact-pill pill-muted">@property.UnitNumber</span>
                        </td>

                        <td class="fw-semibold">
                            @property.MonthlyRent.ToString("C")
                        </td>

                        <td>
                            @if (property.PropertyID == selectedPropertyId)
                            {
                                <span class="compact-pill pill-success">Selected</span>
                            }
                            else
                            {
                                <span class="compact-pill pill-dark">Available</span>
                            }
                        </td>

                        <td>
                            <div class="compact-action-group">
                                @if (property.PropertyID == selectedPropertyId)
                                {
                                    <button class="btn btn-sm btn-secondary compact-action" disabled>
                                        Current
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-success compact-action"
                                            @onclick="() => SaveSelectedPropertyAsync(property.PropertyID)">
                                        Choose
                                    </button>
                                }

                                <a class="btn btn-sm btn-outline-info compact-action"
                                       href="/properties/details/@property.PropertyID">
                                    Details
                                </a>

                                <a class="btn btn-sm btn-outline-primary compact-action"
                                       href="/properties/edit/@property.PropertyID">
                                    Edit
                                </a>

                                <a class="btn btn-sm btn-outline-danger compact-action"
                                       href="/properties/delete/@property.PropertyID">
                                    Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private const string SelectedPropertyKey = "propertyManagement.selectedPropertyId";

    private List<PropertyDto>? properties;
    private int selectedPropertyId;

    private PropertyDto? SelectedProperty =>
        properties?.FirstOrDefault(p => p.PropertyID == selectedPropertyId);

    protected override async Task OnInitializedAsync()
    {
        await LoadProperties();

        var savedValue = await JS.InvokeAsync<string?>("localStorage.getItem", SelectedPropertyKey);

        if (int.TryParse(savedValue, out var savedPropertyId))
        {
            selectedPropertyId = savedPropertyId;
        }
    }

    private async Task LoadProperties()
    {
        properties = await Http.GetFromJsonAsync<List<PropertyDto>>("api/properties") ?? new();
    }

    private async Task SelectPropertyAsync(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var propertyId))
        {
            await SaveSelectedPropertyAsync(propertyId);
        }
    }

    private async Task SaveSelectedPropertyAsync(int propertyId)
    {
        selectedPropertyId = propertyId;

        await JS.InvokeVoidAsync("localStorage.setItem", SelectedPropertyKey, propertyId.ToString());

        Notify.Success(propertyId == 0 ? "All properties selected." : "Property selected.");
    }
}