@page "/rent-collection"
@using PropertyManagementApp.Shared.DTOs
@inject HttpClient Http

<h2 class="mb-4">Rent Collection Dashboard</h2>

@if (schedules == null)
{
    <p>Loading...</p>
}
else
{
    <div class="dashboard-cards">
        <div class="card">
            <h4>Total Due</h4>
            <p>@TotalDue.ToString("C")</p>
        </div>

        <div class="card success">
            <h4>Collected</h4>
            <p>@TotalPaid.ToString("C")</p>
        </div>

        <div class="card warning">
            <h4>Outstanding</h4>
            <p>@Outstanding.ToString("C")</p>
        </div>

        <div class="card danger">
            <h4>Late</h4>
            <p>@LateCount</p>
        </div>
    </div>

    @if (message != null)
    {
        <div class="alert alert-success">
            @message
        </div>
    }



    <table class="table modern-table">
        <thead>
            <tr>
                <th>Tenant</th>
                <th>Property</th>
                <th>Unit</th>
                <th>Due</th>
                <th>Status</th>
                <th>Rent</th>
                <th>Late Fee</th>
                <th>Paid</th>
                <th>Balance</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var s in schedules)
            {
                <tr>
                    <td>@s.TenantName</td>
                    <td>@s.PropertyName</td>
                    <td>@s.UnitNumber</td>
                    <td>@s.DueDate.ToShortDateString()</td>

                    <td>
                        <span class="badge @GetStatusClass(s.Status)">
                            @s.Status
                        </span>
                    </td>

                    <td>@s.BaseRent.ToString("C")</td>
                    <td>@s.LateFeeAccrued.ToString("C")</td>
                    <td>@s.AmountPaid.ToString("C")</td>
                    <td><b>@s.Balance.ToString("C")</b></td>

                    <td>
                        @if (s.Status == "Paid")
                        {
                            <span class="badge badge-success">Complete</span>
                        }
                        else
                        {
                            <div class="action-buttons">
                                <button class="action-btn action-paid"
                                        @onclick="() => MarkPaid(s)">
                                    Mark Paid
                                </button>

                                <button class="action-btn action-fee"
                                        @onclick="() => ApplyLateFee(s)">
                                    Late Fee
                                </button>

                                <button class="action-btn action-reminder"
                                        @onclick="() => SendReminder(s)">
                                    Reminder
                                </button>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<RentScheduleDto>? schedules;

    protected override async Task OnInitializedAsync()
    {
        await LoadSchedules();
    }

    private async Task LoadSchedules()
    {
        schedules = await Http.GetFromJsonAsync<List<RentScheduleDto>>("api/rentschedules");
    }

    private decimal TotalDue => schedules?.Sum(x => x.BaseRent + x.LateFeeAccrued) ?? 0;
    private decimal TotalPaid => schedules?.Sum(x => x.AmountPaid) ?? 0;
    private decimal Outstanding => schedules?.Sum(x => x.Balance) ?? 0;
    private int LateCount => schedules?.Count(x => x.Status == "Late") ?? 0;

    private string GetStatusClass(string? status)
    {
        return status switch
        {
            "Paid" => "badge-success",
            "Late" => "badge-danger",
            "Partial" => "badge-warning",
            _ => "badge-default"
        };
    }

    private async Task MarkPaid(RentScheduleDto schedule)
    {
        var payment = new MarkPaidDto
        {
            AmountPaid = schedule.Balance,
            PaymentMethod = "ACH",
            TransactionRef = "Manual dashboard payment"
        };

        await Http.PostAsJsonAsync($"api/rentschedules/{schedule.ScheduleID}/mark-paid", payment);

        message = $"{schedule.TenantName} marked as paid.";

        await LoadSchedules();
    }

    private async Task ApplyLateFee(RentScheduleDto schedule)
    {
        await Http.PostAsync($"api/rentschedules/{schedule.ScheduleID}/apply-late-fee", null);
        await LoadSchedules();
    }

    private string? message;

    private async Task SendReminder(RentScheduleDto schedule)
    {
        var dto = new CreateCommunicationLogDto
        {
            TenantID = schedule.TenantID,
            ScheduleID = schedule.ScheduleID,
            Channel = "SMS",
            TemplateUsed = "Rent Reminder",
            MessageBody = $"Reminder sent to {schedule.TenantName} for {schedule.Balance:C}"
        };

        await Http.PostAsJsonAsync("api/communications", dto);

        message = $"Reminder sent to {schedule.TenantName}";

        await LoadSchedules();
    }
}