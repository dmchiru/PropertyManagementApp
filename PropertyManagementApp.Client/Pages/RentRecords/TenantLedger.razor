@page "/rent-records/tenant/{tenantId:int}"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="page-header">
    <div>
        <h3>Tenant Ledger</h3>
        <p class="text-muted mb-0">View charges, payments, and running balance for this tenant.</p>
    </div>

    <div class="compact-action-group">
        <button class="btn btn-sm btn-outline-secondary compact-action" @onclick="BackToRentRecords">
            Back
        </button>

        <button class="btn btn-sm btn-outline-primary compact-action" @onclick="PrintStatement">
            Print
        </button>

        <button class="btn btn-sm btn-outline-success compact-action" @onclick="ExportCsv">
            Export CSV
        </button>
    </div>
</div>

@if (records == null)
{
    <p><em>Loading...</em></p>
}
else if (!records.Any())
{
    <div class="alert alert-info">
        No ledger records found.
    </div>
}
else
{
    <div class="dashboard-cards compact-dashboard-cards">
        <div class="card">
            <h4>Total Charges</h4>
            <p>@TotalCharges.ToString("C")</p>
        </div>

        <div class="card success">
            <h4>Total Payments</h4>
            <p>@TotalPayments.ToString("C")</p>
        </div>

        <div class="card warning">
            <h4>Balance</h4>
            <p>@CurrentBalance.ToString("C")</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Charge</th>
                    <th>Payment</th>
                    <th>Balance</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var record in records)
                {
                    <tr>
                        <td>@record.Date.ToShortDateString()</td>

                        <td class="fw-semibold">
                            @record.Description
                        </td>

                        <td>
                            @if (record.Charge > 0)
                            {
                                <span>@record.Charge.ToString("C")</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>

                        <td>
                            @if (record.Payment > 0)
                            {
                                <span class="text-success fw-semibold">@record.Payment.ToString("C")</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>

                        <td class="fw-semibold">
                            @record.Balance.ToString("C")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter]
    public int tenantId { get; set; }

    private List<LedgerRow>? records;

    private decimal TotalCharges => records?.Sum(record => record.Charge) ?? 0;
    private decimal TotalPayments => records?.Sum(record => record.Payment) ?? 0;
    private decimal CurrentBalance => records?.LastOrDefault()?.Balance ?? 0;

    protected override async Task OnInitializedAsync()
    {
        records = await Http.GetFromJsonAsync<List<LedgerRow>>($"api/rentrecords/{tenantId}") ?? new();
    }

    private void BackToRentRecords()
    {
        Navigation.NavigateTo("/rent-records");
    }

    private async Task PrintStatement()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task ExportCsv()
    {
        if (records == null || !records.Any())
        {
            return;
        }

        var csv = "Date,Description,Charge,Payment,Balance\n";

        foreach (var record in records)
        {
            csv += $"{record.Date:yyyy-MM-dd},\"{record.Description}\",{record.Charge},{record.Payment},{record.Balance}\n";
        }

        await JS.InvokeVoidAsync("downloadFile", $"tenant-ledger-{tenantId}.csv", csv);
    }

    public class LedgerRow
    {
        public DateTime Date { get; set; }
        public string Description { get; set; } = "";
        public decimal Charge { get; set; }
        public decimal Payment { get; set; }
        public decimal Balance { get; set; }
    }
}