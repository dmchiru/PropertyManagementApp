@page "/rent-records/tenant/{tenantId:int}"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<h2>Tenant Ledger</h2>

<div class="ledger-actions">
    <button class="action-btn action-reminder" @onclick="BackToTenants">
        ← Back to Tenants
    </button>

    <button class="action-btn action-paid" @onclick="PrintStatement">
        Print Statement
    </button>

    <button class="action-btn action-fee" @onclick="ExportCsv">
        Export CSV
    </button>
</div>

@if (records == null)
{
    <p>Loading...</p>
}
else if (!records.Any())
{
    <p>No records found.</p>
}
else
{
    <table class="table modern-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Description</th>
                <th>Charge</th>
                <th>Payment</th>
                <th>Balance</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var r in records)
            {
                <tr>
                    <td>@r.Date.ToShortDateString()</td>
                    <td>@r.Description</td>
                    <td>@(r.Charge > 0 ? r.Charge.ToString("C") : "-")</td>
                    <td>@(r.Payment > 0 ? r.Payment.ToString("C") : "-")</td>
                    <td><b>@r.Balance.ToString("C")</b></td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter]
    public int tenantId { get; set; }

    private List<LedgerRow>? records;

    protected override async Task OnInitializedAsync()
    {
        records = await Http.GetFromJsonAsync<List<LedgerRow>>($"api/rentrecords/{tenantId}");
    }

    private void BackToTenants()
    {
        Navigation.NavigateTo("/tenants");
    }

    private async Task PrintStatement()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task ExportCsv()
    {
        if (records == null || !records.Any())
            return;

        var csv = "Date,Description,Charge,Payment,Balance\n";

        foreach (var r in records)
        {
            csv += $"{r.Date:yyyy-MM-dd},\"{r.Description}\",{r.Charge},{r.Payment},{r.Balance}\n";
        }

        await JS.InvokeVoidAsync("downloadFile", $"tenant-ledger-{tenantId}.csv", csv);
    }

    public class LedgerRow
    {
        public DateTime Date { get; set; }
        public string Description { get; set; } = "";
        public decimal Charge { get; set; }
        public decimal Payment { get; set; }
        public decimal Balance { get; set; }
    }
}